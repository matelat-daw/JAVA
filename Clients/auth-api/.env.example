# Variables de Entorno - Ejemplo
# Copiar este archivo a .env y completar con valores reales

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=auth_db
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_SECRET=YourSuperSecureSecretKeyThatIsAtLeast256BitsLongForHSHA256AlgorithmYourSuperSecureSecretKeyThatIsAtLeast256B
JWT_EXPIRATION=86400000

# Email (Gmail)
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-app-gmail
MAIL_FROM=noreply@authapi.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
SERVER_PORT=8081

# Profiles
SPRING_PROFILES_ACTIVE=dev
